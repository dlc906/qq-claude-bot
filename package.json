{
  "name": "claude-code-qq",
  "version": "1.0.0",
  "description": "Bridge QQ messages to Claude Code CLI",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "dev:web": "cd web && npm run dev",
    "dev:all": "concurrently -n back,front -c blue,green \"npm run dev\" \"npm run dev:web\"",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@types/node": "^26.0.0",
    "dotenv": "^17.4.2",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.1",
    "qq-bot-sdk": "^1.11.1",
    "sql.js": "^1.14.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3"
  }
}
