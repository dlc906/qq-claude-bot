# QQ Bot credentials (from https://q.qq.com)
QQ_APP_ID=your_app_id
QQ_APP_SECRET=your_app_secret

# QQ Bot sandbox mode (true for testing, false for production)
QQ_SANDBOX=true

# Claude Code path (if not in PATH)
CLAUDE_PATH=claude

# Max concurrent Claude calls
MAX_CONCURRENT=3

# Reply timeout in seconds
CLAUDE_TIMEOUT=120

# API port for chat history viewer
API_PORT=3800

# LLM provider: 'claude-code', 'openai', or 'anthropic' (can also be changed in web UI)
LLM_PROVIDER=claude-code

# OpenAI compatible API settings
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic API settings
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
